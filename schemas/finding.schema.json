{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string" }
        },
        "required": ["finding_id", "description", "status"]
      }
    }
  },
  "required": ["schema_version", "findings"]
}