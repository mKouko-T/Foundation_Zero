{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Architecture Decision Record",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "Repository",
        "Protocol",
        "Specification",
        "Architecture",
        "Governance",
        "Tooling"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Proposed",
        "Accepted",
        "Rejected",
        "Deprecated",
        "Superseded"
      ]
    },
    "context": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "consequences": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "id",
    "title",
    "category",
    "status",
    "decision"
  ]
}