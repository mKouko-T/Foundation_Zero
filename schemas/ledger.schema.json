{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Certification Ledger",
  "description": "Schema for the Foundation Zero Certification Ledger",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "compatible_protocol_versions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatible_fzs_versions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "proposition": {
            "type": "string"
          },
          "provenance": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "proposition",
          "provenance",
          "status"
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "candidates"
  ]
}